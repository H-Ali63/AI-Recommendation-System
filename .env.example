# ============================================================
# RecommendAI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
APP_NAME=RecommendAI
APP_VERSION=1.0.0

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Frontend ---
FRONTEND_PORT=8501
BACKEND_URL=http://backend:8000   # Use http://localhost:8000 for local dev

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=recommendai
MONGO_COLLECTION_ITEMS=movies
MONGO_COLLECTION_INTERACTIONS=interactions
MONGO_COLLECTION_CACHE=recommendation_cache

# --- Redis Cache ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600                # Cache TTL in seconds (1 hour)

# --- ML Model ---
DATA_PATH=data/raw/movies.csv
MODEL_CACHE_DIR=model/cache
TOP_N_DEFAULT=10
SIMILARITY_THRESHOLD=0.1

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60          # seconds
